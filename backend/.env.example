PORT=4000
NODE_ENV=development

# DB
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/DBNAME

# Auth
# Usar 64+ chars aleatorios: `openssl rand -base64 48`
JWT_SECRET=pon_un_secret_largo_y_unico

# Frontend (CORS)
CLIENT_URL=http://localhost:5173
# CLIENT_URLS=http://localhost:5173,https://tu-frontend.vercel.app
FRONTEND_URL=http://localhost:5173

# Email (opcional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Cloudinary (para comprobantes de pago)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Mercado Pago — credenciales de la cuenta vendedora
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_STORE_IMAGE_URL=

# Mercado Pago — clave secreta para firmar webhooks
# Se obtiene en el panel de MP:
#   Tus integraciones → tu integración → Webhooks → "Clave secreta"
# Sin esto el webhook responde 401 a todas las notificaciones.
MP_WEBHOOK_SECRET=
